# Slack
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_SIGNING_SECRET=your-signing-secret

# SlackチャンネルID（各チャンネルの設定 > チャンネル詳細 > チャンネルIDをコピー）
SLACK_CHANNEL_INSTAGRAM=C000000001
SLACK_CHANNEL_TIKTOK=C000000002
SLACK_CHANNEL_X=C000000003
SLACK_CHANNEL_GUMROAD=C000000004

# Google Sheets
GOOGLE_CREDENTIALS_FILE=config/google_credentials.json
SPREADSHEET_ID=your-spreadsheet-id

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key

# 担当者名（実際の名前に変更してください）
MEMBER_1_NAME=Shu
MEMBER_2_NAME=Partner

# 通知時間（HH:MM形式、JSTで指定）
REMINDER_TIME_1=09:00
REMINDER_TIME_2=13:00
